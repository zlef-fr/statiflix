{
  "manifest_version": 3,
  "name": "Statiflix — Your Netflix Viewing, Quantified",
  "version": "2.0.0",
  "description": "Turn your Netflix watch history into a private, Wrapped-style dashboard — genres, binge hours, abandoned shows. 100% local.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Statiflix",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["*://*.netflix.com/*", "https://statiflix.zlef.fr/*"],
  "background": { "service_worker": "sw.js" }
}
